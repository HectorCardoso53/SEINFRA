# Banco de dados PostgreSQL
DATABASE_URL=postgresql://seinfra:SENHA_AQUI@localhost:5432/seinfra

# Segredo JWT (gere um aleatório: openssl rand -hex 64)
JWT_SECRET=coloque_um_segredo_longo_e_aleatorio_aqui

# Senha do Postgres (usada no docker-compose)
POSTGRES_PASSWORD=SENHA_AQUI

# Porta da API
PORT=3001
